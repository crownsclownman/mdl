; Microcode Description Language

; 1. Определение входных линий (адресное пространство ПЗУ)
; Общий размер адреса: 8 (opcode) + 4 (status) + 2 (upc) = 14 бит (16384 ячейки)
.input
    opcode[8]           ; Базовое смещение инструкции (биты 13..6)
    status[4]           ; Поле флагов для условий ветвления (биты 5..2)
    upc[2] @step        ; Физический счетчик микрошагов (биты 1..0)
.end

; 2. Определение выходных линий ПЗУ (управляющие сигналы)
; Общая ширина выхода: 5 бит (в ПЗУ будет округлено до 8 бит / 1 байта)
.output
    pc_inc      ; бит 0
    a_in        ; бит 1
    alu_op[2]   ; биты 3..2 (двухбитное поле)
    upc_clr     ; бит 4
.end

; Секция инструкций

;  Инструкция 0x00: Демонстрация ветвления и схождения веток
;  Здесь ".opcode 0x00" это имя поля из ".input" вместе с значением
.opcode 0x00
    ; Шаг 0 (step = 0). Выполняется ВСЕГДА.
    ; Компилятор дублирует эту команду во все 16 комбинаций поля status.
    pc_inc | a_in | alu_op=2

    ; Шаг 1 (step = 1). Выполняется ВСЕГДА.
    ; Компилятор дублирует по всем status. LocalCounter инкрементируется.
    alu_op=1 | pc_inc

    ; Шаг 2 (step = 2). ВЕТВЛЕНИЕ.
    ; Так как обе строки содержат '@', LocalCounter НЕ инкрементируется между ними.
    ; Ветка А: если status[0] == 1 (8 ячеек ПЗУ из 16 на этом шаге)
    alu_op=1 @status[0]

    ; Ветка Б: если status[0] == 0 (остальные 8 ячеек ПЗУ на этом шаге)
    alu_op=0 | pc_inc @!status[0]

    ; Шаг 3 (step = 3). СХОЖДЕНИЕ ВЕТОК.
    ; Строка без условий. Компилятор видит выход из блока '@' и делает инкремент.
    ; Команда запишется во все 16 ячеек шага 3.
    ; В железе счетчик сделает +1 и из 0x0002 (Ветка Б), и из 0x0012 (Ветка А),
    ; попав в любом случае на эту команду (по адресам 0x0003 и 0x0013 соответственно).
    a_in | upc_clr
.end 0x00

;  Инструкция 0x01: Простая линейная последовательность
.opcode 0x01
    ; Шаг 0 (step = 0). Выполняется всегда.
    alu_op=2 | a_in

    ; Шаг 1 (step = 1). Выполняется всегда. LocalCounter = 1.
    pc_inc

    ; Шаг 2 (step = 2). Выполняется всегда. LocalCounter = 2.
    ; Сбрасываем счетчик микрокоманд, чтобы не выйти за рамки 2-битного upc.
    upc_clr
.end 0x01
